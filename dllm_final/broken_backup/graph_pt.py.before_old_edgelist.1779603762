    raise SystemExit("ERROR: graph_pt.py is still the patch script, not the real old training file.")

# Imports.
if "from dllm.utils.graph_edge_list_strategy import build_edge_list_strategy" not in s:
    marker = "from dllm.utils.graph_token_strategies import (\n"
    if marker not in s:
        raise SystemExit("Could not find graph_token_strategies import block.")
    insert = "from dllm.utils.graph_edge_list_strategy import build_edge_list_strategy\n"
    s = s.replace("from graph_evaluation import GraphEvaluatorCallback\n", insert + "from graph_evaluation import GraphEvaluatorCallback\n", 1)

if "from dllm.utils.eval_utils import run_graph_generation_eval" not in s:
    s = s.replace(
        "from graph_evaluation import GraphEvaluatorCallback\n",
        "from graph_evaluation import GraphEvaluatorCallback\nfrom dllm.utils.eval_utils import run_graph_generation_eval\n",
        1,
    )

# Strategy list.
s = re.sub(
    r'VALID_STRATEGIES\s*=\s*\([^\)]*\)',
    'VALID_STRATEGIES = ("original", "text_mapping", "selective_special", "edge_list")',
    s,
    count=1,
)

# Help text.
s = s.replace(
    "Choices: original | text_mapping | selective_special.",
    "Choices: original | text_mapping | selective_special | edge_list.",
)

# Add dataset builder.
builder_marker = "# ---------------------------------------------------------------------------\n# Main training function\n# ---------------------------------------------------------------------------"
builder_code = r'''
def build_token_dataset_edge_list(
    graphs,
    lm_strategy,
    lm_tokenizer,
    *,
    max_length: int,
    test_size: float,
    seed: int,
    append_eos: bool = True,
):
    """Build LM-token dataset from compact edge-list strings."""
    rows = []

    for graph in graphs:
        text = lm_strategy.prompt + lm_strategy.encode_to_text(graph)
        input_ids = lm_tokenizer.encode(text, add_special_tokens=False)

        if append_eos and lm_tokenizer.eos_token_id is not None:
            input_ids = input_ids + [lm_tokenizer.eos_token_id]

        if len(input_ids) > max_length:
            continue

        rows.append(
            {
                "input_ids": input_ids,
                "labels": input_ids.copy(),
            }
        )

    if not rows:
        raise ValueError(
            "No edge-list graph samples survived tokenization. "
            "Try increasing --max_length or lowering --max_nodes_per_graph."
        )

    dataset = datasets.Dataset.from_list(rows)
    if test_size <= 0.0:
        return datasets.DatasetDict({"train": dataset})

    return dataset.train_test_split(test_size=test_size, seed=seed)
'''

