#!/usr/bin/env bash
#SBATCH --job-name=eval.job
#SBATCH --partition=gpu_a100
#SBATCH --gpus=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=9
#SBATCH --time=12:00:00
#SBATCH --output=outputs/eval_%A.out
#SBATCH --error=outputs/eval_%A.err

set -euo pipefail

mkdir -p outputs

# Match the README-style environment, then activate the installed env.
module purge
module load 2024
module load GCC/13.3.0
module load Miniconda3/24.7.1-0
module load Mamba/24.9.0-0

source "$(conda info --base)/etc/profile.d/conda.sh"

# Some conda activation hooks expect unset variables to be harmless.
# `set -u` makes them fatal unless we relax nounset for activation.
export NVCC_PREPEND_FLAGS="${NVCC_PREPEND_FLAGS:-}"
set +u
conda activate dllm
set -u

export PYTHONNOUSERSITE=1
export PYTHONPATH=.
export NCCL_ASYNC_ERROR_HANDLING=1

MODEL_PATH="${MODEL_PATH:-.models/Qwen3/mdlm/graph-pt/checkpoint-final}"

time python -u examples/a2d/mdlm/evaluate.py \
  --model_path "${MODEL_PATH}" \
  --pyg_dataset MalNet
